# --- TED (EU Tenders Electronic Daily) ---
# Search API не изисква ключ. Базовият URL рядко се мени.
TED_API_BASE=https://api.ted.europa.eu/v3

# Колко дни назад да гледа discovery агентът при всяко пускане
DISCOVERY_LOOKBACK_DAYS=30

# Само обявления за поръчка (cn-standard). Празно = всички типове.
DISCOVERY_NOTICE_TYPE=cn-standard

# --- Claude (за класификатора и документиста) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8

# --- Каталог (за мачване на спецификации) ---
# По-късно: четене на Infinita продукти за оценка на съответствие.
# Вариант 1: Odoo XML-RPC/SQL export; Вариант 2: статичен JSON export.
CATALOG_SOURCE=static
CATALOG_PATH=./data/catalog.json

# --- Email напомняния (Resend, както в Skyrent) ---
RESEND_API_KEY=
ALERT_EMAIL=ivollazarov@gmail.com

# --- Server ---
PORT=4010

# --- Cron (за Railway: върти конвейера в самия backend процес) ---
ENABLE_CRON=false
CRON_SCHEDULE=0 7 * * *

# --- Данни (Railway: насочи към прикачен Volume за да оцелява db.json при деплой) ---
# DB_PATH=/data/db.json
# DRAFTS_DIR=/data/drafts
